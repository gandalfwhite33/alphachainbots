# ─── Hyperliquid Bot — Configuración ─────────────────────────────────────────
# Copia este archivo a ".env" y rellena los valores

# Modo testnet (true) o mainnet real (false)
TESTNET=true

# Clave privada de tu wallet Ethereum (sin el prefijo 0x)
# ⚠️  NUNCA compartas ni subas al repo esta clave
PRIVATE_KEY=tu_clave_privada_aqui

# Dirección del wallet (opcional — se deriva automáticamente de PRIVATE_KEY si está vacío)
ACCOUNT_ADDRESS=
